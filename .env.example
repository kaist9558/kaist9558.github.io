# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
# 모델 — 기본 claude-sonnet-4-6 (요약 작업에 비용/품질 균형 우수)
# 필요 시 claude-haiku-4-5 (저비용) 또는 claude-opus-4-7 (고품질)
CLAUDE_MODEL=claude-sonnet-4-6

# 보도자료 룩백 일수 (기본 1 — 매일 실행 시)
LOOKBACK_DAYS=1

# 로그 레벨
LOG_LEVEL=INFO

# ----------------------------------------------------------------
# 아래는 GitHub Actions에서 자동 주입됩니다 — 로컬 테스트는 --dry-run 권장.
# 로컬에서 실제 Issue를 생성하려는 경우에만 직접 설정:
#   GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx  (repo:issues 권한 필요)
#   GITHUB_REPOSITORY=kaist9558/kaist9558.github.io
# ----------------------------------------------------------------
