# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
# 모델 — 기본 claude-sonnet-4-6 (요약 작업에 비용/품질 균형 우수)
# 필요 시 claude-haiku-4-5 (저비용) 또는 claude-opus-4-7 (고품질)
CLAUDE_MODEL=claude-sonnet-4-6

# 이메일 (Gmail 사용 시 앱 비밀번호 필요: https://support.google.com/accounts/answer/185833)
EMAIL_SENDER=your.address@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECEIVER=recipient@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 보도자료 룩백 일수 (기본 1 — 매일 실행 시)
LOOKBACK_DAYS=1

# 로그 레벨
LOG_LEVEL=INFO
